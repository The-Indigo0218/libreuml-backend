# Copy this file to .env and fill in the values before running docker-compose.

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=libreumldb
DB_USER=postgres
DB_PASSWORD=changeme

# ── Application ───────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_-base64_64
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_ME_strong_password
# Comma-separated IPs/CIDRs of trusted reverse proxies. Supports CIDR notation.
# Add 172.0.0.0/8 to trust the Docker bridge network where nginx runs.
# For Cloudflare: add their IP ranges from https://www.cloudflare.com/ips/
TRUSTED_PROXIES=127.0.0.1,::1,172.0.0.0/8

# ── Domain (required for production HTTPS via init-letsencrypt.sh) ───────────
DOMAIN=api.yourdomain.com
CERTBOT_EMAIL=admin@yourdomain.com

# ── Frontend ──────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com
FRONTEND_URL=https://app.yourdomain.com

# ── Mail ──────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_AUTH=true
SMTP_STARTTLS=true
MAIL_FROM=noreply@yourdomain.com

# ── OAuth2 Credentials ────────────────────────────────────────────────────────
# Register apps at: https://github.com/settings/developers
GITHUB_CLIENT_ID=CHANGE_ME
GITHUB_CLIENT_SECRET=CHANGE_ME
# Register apps at: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME

# ── Observability ─────────────────────────────────────────────────────────────
# 1.0 = 100% sampling (use lower values in high-traffic production)
TRACING_PROBABILITY=0.1
OTLP_ENDPOINT=http://your-otel-collector:4318/v1/traces

# ── Audit log ─────────────────────────────────────────────────────────────────
AUDIT_RETENTION_DAYS=90
